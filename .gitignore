# Dependencies
node_modules/
vendor/

# Build outputs
# js/ - NOT ignored, needed for App Store
dist/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Temporary files
*.swp
*.swo
*~

# Deployment artifacts
*.tar.gz
*.sig
intravox-deploy/

# Demo data images (downloaded/generated content)
demo-data/*/images/

# Logs
*.log

# Translation templates — only the POT source is tracked; per-language .po
# files are generated by the Nextcloud l10n sync-bot and land here on PR.
translationfiles/*
!translationfiles/templates/
!translationfiles/templates/*.pot

# l10n/en.json is a generated build artifact (scripts/extract-en-json.js); the
# NC Transifex bot also deletes it after sync. Never commit it.
# NOTE: l10n/.source-count.json IS committed on purpose — it holds the source-
# string total used as the denominator for the admin translation-coverage % at
# runtime (en.json is absent on the server). Do not add it here.
l10n/en.json

# Package lock files (use composer.lock for PHP)
package-lock.json

# Local development scripts (if any remain)
*.local.sh
*.local.js

# Deployment and release scripts (local use only)
create-release.sh
deploy-demo-data.sh
deploy.sh
deploy-*.sh
check-*.sh

# Code signing certificates (private keys must never be committed!)
*.key
*.csr
*.crt
*.pem

# Backup files
*.bak

# macOS metadata
._*

# Claude Code configuration
.claude/
CLAUDE.md

# Internal documentation (for Gitea only, not GitHub)
docs/internal/

# Test data (local development only)
testdata/
.phpunit.cache/
scripts/.cache/
